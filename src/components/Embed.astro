---
interface Props {
  src: string;
  title?: string;
}
const { src, title = 'Embedded video' } = Astro.props;
---
<div class="my-6 aspect-video">
  <iframe
    src={src}
    title={title}
    class="w-full h-full rounded"
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>
