---
import { getCollection } from 'astro:content';
import Prose from '../layouts/Prose.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  const paths = [];

  for (const entry of pages) {
    // Canonical route
    paths.push({
      params: { slug: entry.data.permalink },
      props: { entry, redirect: null },
    });

    // Redirect routes for old URLs
    for (const oldSlug of entry.data.redirectFrom) {
      paths.push({
        params: { slug: oldSlug },
        props: { entry: null, redirect: `/${entry.data.permalink}` },
      });
    }
  }

  return paths;
}

const { entry, redirect } = Astro.props;

if (redirect) {
  return Astro.redirect(redirect, 301);
}

const { Content } = await entry.render();
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Prose title={entry.data.title} backHref="/" backLabel="contents">
  <h1 class="font-heading dark:text-dark-heading">{entry.data.title}</h1>
  {entry.data.stub ? (
    <p class="text-black dark:text-dark-muted italic mt-4">This article hasn't been written yet. Check back soon!</p>
  ) : (
    <>
      <p class="text-sm text-black dark:text-dark-muted">
        Published {fmt(entry.data.published)}
        {entry.data.edited && <span> · Edited {fmt(entry.data.edited)}</span>}
      </p>
      <Content />
    </>
  )}
  <hr class="my-8 border-gray-200 dark:border-gray-800" />
  <nav class="not-prose flex gap-4 text-sm text-black dark:text-dark-muted">
    <a href="#top" class="hover:text-accent-light dark:hover:text-dark-heading">to top</a>
    <a href="/" class="hover:text-accent-light dark:hover:text-dark-heading">main</a>
  </nav>
</Prose>
