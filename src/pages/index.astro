---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const allPages = await getCollection('pages');
const pageMap = Object.fromEntries(allPages.map(p => [p.data.permalink, p]));

// Table of contents structure: [permalink, display title]
const toc = {
  intro: [
    ['preface', 'Preface: Towards Software Design'],
  ],
  'I. Product, Software, AI': [
    ['product-and-software', 'Product and Software'],
    ['the-saaspocalypse', 'The SaaSpocalypse'],
    ['what-is-ai', 'What is AI?'],
    ['artifact-driven-development', 'Artifact Driven Development'],
    ['good-code', 'Good Code'],
  ],
  'II. Spec Driven Development': [
    ['two-sources-of-truth', 'Two Sources of Truth'],
    ['specs-and-ai', 'Specs and AI'],
    ['transformation-distillation-enrichment', 'Transformation, Distillation, Enrichment'],
    ['code-maps', 'Code Maps'],
  ],
  'III. Software Design': [
    ['the-software-designer', 'The Software Designer'],
    ['meet-the-team', 'Meet the Team'],
    ['craftsmanship', 'Craftsmanship'],
  ],
};
---
<Base title="Computation">
  <h1 class="font-heading text-5xl font-bold mb-3 tracking-tight text-center dark:text-dark-heading">Computation</h1>
  <p class="text-center text-sm text-gray-400 dark:text-dark-muted mb-16 italic">Software Design, and Machine Software</p>

  <p class="text-sm text-gray-400 dark:text-dark-muted italic mb-10">Pages are being added over time. Placeholders are denoted with (·). Thank you for reading!</p>

  {Object.entries(toc).map(([section, entries]) => (
    <>
      {section !== 'intro' && <h2 class="font-heading text-2xl font-bold mb-6 dark:text-dark-heading">{section}</h2>}
      <ul class="space-y-3 mb-14 pl-4">
        {entries.map(([permalink, title]) => {
          const page = pageMap[permalink];
          if (page && !page.data.stub) {
            return <li><a href={`/${permalink}`} class="text-accent-light dark:text-accent-dark hover:underline">{title}</a></li>;
          } else if (page?.data.stub) {
            return <li class="text-gray-400 dark:text-dark-muted">{title} <a href={`/${permalink}`} class="text-accent-light dark:text-accent-dark hover:underline text-xs">(·)</a></li>;
          } else {
            return <li class="text-gray-400 dark:text-dark-muted">{title}</li>;
          }
        })}
      </ul>
    </>
  ))}

  <hr class="my-6 border-gray-200 dark:border-gray-800" />

  <div class="flex items-center justify-center gap-4">
    <p class="text-sm text-gray-400 dark:text-dark-muted">
      <a href="/blog" class="text-accent-light dark:text-accent-dark hover:underline">Blog</a>
      <span class="ml-2">&middot;</span>
      <a href="https://github.com/saxonthune/computation-site" class="text-accent-light dark:text-accent-dark hover:underline ml-2">GitHub</a>
      <span class="ml-2">&middot;</span>
    <ThemeToggle />
    </p>
  </div>
</Base>
