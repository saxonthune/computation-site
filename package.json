  },
  "dependencies": {
    "@astrojs/markdoc": "^0.15.10",
    "@astrojs/rss": "^4.0.0",
    "astro": "^5.17.1"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "@tailwindcss/typography": "^0.5.15",
    "tailwindcss": "^3.4.0"
  }
}
